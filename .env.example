# LLM provider API keys — fill in whichever you use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (self-hosted) — setting OLLAMA_BASE_URL activates this provider automatically
# Example: OLLAMA_BASE_URL=http://192.168.1.50:11434/v1
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# Secret key — used to sign session cookies; set to a long random string
SECRET_KEY=change-me

# PostgreSQL — defaults match compose.yml; override for an external DB
DATABASE_URL=postgresql://jarvis:jarvis@postgres/jarvis
POSTGRES_PASSWORD=jarvis

# Authentik OIDC — create an OAuth2/OIDC provider in Authentik and paste values here
# Redirect URI to register in Authentik: {APP_URL}/auth/callback
AUTHENTIK_URL=https://auth.example.com
OIDC_APP_SLUG=jarvis
# OIDC_DISCOVERY_URL is built automatically from AUTHENTIK_URL + OIDC_APP_SLUG.
# Only set this if your discovery URL doesn't follow the standard Authentik pattern.
# OIDC_DISCOVERY_URL=https://auth.example.com/application/o/jarvis/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Public URL of this app — used to build the OIDC redirect URI
APP_URL=http://localhost:5000

# Authentik group whose members get the admin role (everyone else gets 'user')
OIDC_ADMIN_GROUP=jarvis-admins

# Tesla Fleet API (optional — only needed for the official Fleet API integration)
# Register your app at developer.tesla.com to get these.
# The unofficial API path does not require these values.
# Redirect URI to register: {APP_URL}/auth/tesla/callback
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
